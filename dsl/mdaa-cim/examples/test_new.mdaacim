AudioGenerator {
    id "gen1"
    name "Oscillator 1"
    description "A high quality sine wave oscillator"
    inputs "Midi gate, pitch"
    outputs "Sine wave signal"
    params "Frequency, sweep"
    ref [
        {
            id "mod1"
            description "Reference to the modulator"
        }
    ]
    rel []
}

Modificator {
    id "mod1"
    name "LFO 1"
    description "Low frequency oscillator for modulation"
    inputs "Reset trigger"
    outputs "Modulation signal"
    params "Rate, depth"
    ref []
}
