{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MDA Audio PIM Machine Schema",
  "type": "object",
  "required": ["id", "name", "ids_cim_reference", "nodes", "edges"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 20
    },
    "description": {
      "type": "string",
      "minLength": 20,
      "maxLength": 600
    },
    "ids_cim_reference": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^.{36}$"
      }
    },
    "nodes": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/Node"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/Edge"
      }
    }
  },
  "definitions": {
    "Parameter": {
      "type": "object",
      "required": ["id", "ids_references", "initialValue", "isModifiable"],
      "properties": {
        "id": { "type": "string", "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$" },
        "ids_references": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "initialValue": { "anyOf": [{ "type": "number" }, { "type": "string" }, { "type": "boolean" }, { "$ref": "#/definitions/Matrix" }] },
        "isModifiable": { "type": "boolean" },
        "isExternalInput": { "type": "boolean" },
        "description": { "type": "string", "maxLength": 600 }
      }
    },
    "ConnectionPoint": {
      "type": "object",
      "required": ["id", "ids_references"],
      "properties": {
        "id": { "type": "string", "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$" },
        "ids_references": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "isExternalInput": { "type": "boolean" },
        "isExternalOutput": { "type": "boolean" },
        "description": { "type": "string", "maxLength": 600 }
      }
    },
    "Matrix": {
      "type": "array",
      "minItems": 4,
      "maxItems": 1000,
      "items": {
        "type": "array",
        "items": { "type": "number", "enum": [0, 1] }
      }
    },
    "CommonNodeFields": {
      "type": "object",
      "required": ["id", "name", "description", "ids_references", "others"],
      "properties": {
        "id": { "type": "string", "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$" },
        "name": { "type": "string", "minLength": 1, "maxLength": 20 },
        "description": { "type": "string", "maxLength": 600 },
        "ids_references": { "type": "array", "items": { "type": "string" } },
        "others": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "name", "ids_references", "initialValue", "isModifiable"],
            "properties": {
              "id": { "type": "string", "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$" },
              "name": { "type": "string", "minLength": 1, "maxLength": 20 },
              "ids_references": { "type": "array", "minItems": 1, "items": { "type": "string" } },
              "initialValue": { "type": "string", "minLength": 1, "maxLength": 100 },
              "isModifiable": { "type": "boolean" },
              "isExternalInput": { "type": "boolean" },
              "description": { "type": "string", "maxLength": 600 }
            }
          }
        }
      }
    },
    "Node": {
      "type": "object",
      "allOf": [
        { "$ref": "#/definitions/CommonNodeFields" },
        {
          "oneOf": [
            { "required": ["type", "waveform", "frequency", "pulseWidth", "gain", "phase", "pan", "stereo", "output_1"], "properties": { "type": { "const": "oscillator" } } },
            { "required": ["type", "noiseType", "amplitude", "gain", "pan", "stereo", "output_1"], "properties": { "type": { "const": "noise" } } },
            { "required": ["type", "file", "loop", "gain", "pan", "stereo", "output_1"], "properties": { "type": { "const": "sample" } } },
            { "required": ["type", "filterType", "cutoff", "resonance", "slope", "stereo", "input_1", "output_1"], "properties": { "type": { "const": "frequency_filter" } } },
            { "required": ["type", "waveform", "rate", "amplitude", "phase", "sync", "output"], "properties": { "type": { "const": "lfo" } } },
            { "required": ["type", "envelopeType", "attack", "decay", "sustain", "release", "curve", "output"], "properties": { "type": { "const": "envelope" } } },
            { "required": ["type", "stereo", "inputs_number", "output_1"], "properties": { "type": { "const": "mixer" } } },
            { "required": ["type", "gain", "pan", "stereo", "input_1", "output_1"], "properties": { "type": { "const": "gain_pan" } } },
            { "required": ["type", "roomSize", "damping", "decayTime", "dryWet", "stereo", "input_1", "output_1"], "properties": { "type": { "const": "reverb" } } },
            { "required": ["type", "delayTime", "feedback", "lowPassCutoff", "highPassCutoff", "dryWet", "stereo", "input_1", "output_1"], "properties": { "type": { "const": "delay" } } },
            { "required": ["type", "drive", "tone", "distType", "outputLevel", "stereo", "input_1", "output_1"], "properties": { "type": { "const": "distortion" } } },
            { "required": ["type", "rate", "depth", "feedback", "mix", "stereo", "input_1", "output_1"], "properties": { "type": { "const": "chorus_flanger" } } },
            { "required": ["type", "threshold", "ratio", "attack", "release", "makeupGain", "stereo", "input_1", "output_1"], "properties": { "type": { "const": "compressor" } } },
            { "required": ["type", "bandFrequency", "bandwidth", "gain", "stereo", "input_1", "output_1"], "properties": { "type": { "const": "equalizer" } } }
          ]
        }
      ]
    },
    "Edge": {
      "type": "object",
      "required": ["id", "description", "ids_references", "sourceNode", "sourceParam", "targetNode", "targetParam", "type"],
      "properties": {
        "id": { "type": "string", "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$" },
        "description": { "type": "string", "maxLength": 600 },
        "ids_references": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "sourceNode": { "type": "string" },
        "sourceParam": { "type": "string" },
        "targetNode": { "type": "string" },
        "targetParam": { "type": "string" },
        "type": { "enum": ["audio", "modification"] }
      }
    }
  }
}
