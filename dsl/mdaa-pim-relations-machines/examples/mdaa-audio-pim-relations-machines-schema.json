{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "MDA-Audio PIM Relations Machine Schema",
    "description": "Esquema de validación para las relaciones entre máquinas PIM en el sistema MDA-Audio.",
    "type": "object",
    "properties": {
        "description": {
            "type": "string",
            "minLength": 1,
            "maxLength": 600,
            "description": "Descripción general del propósito de la red de relaciones."
        },
        "relations": {
            "type": "array",
            "description": "Lista de relaciones granulares entre puntos PIM.",
            "items": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "string",
                        "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$",
                        "description": "Identificador único de la relación (UUID)."
                    },
                    "source": {
                        "type": "string",
                        "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$",
                        "description": "ID del punto de salida (output) de una máquina PIM."
                    },
                    "destination": {
                        "type": "string",
                        "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$",
                        "description": "ID del punto de entrada (input) o parámetro de una máquina PIM."
                    },
                    "description": {
                        "type": "string",
                        "minLength": 10,
                        "maxLength": 300,
                        "description": "Descripción técnica de la modulación o conexión de audio."
                    }
                },
                "required": ["id", "source", "destination", "description"],
                "additionalProperties": false
            }
        }
    },
    "required": ["relations"],
    "additionalProperties": false
}
