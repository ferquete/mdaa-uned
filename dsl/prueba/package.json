{
  "name": "prueba-langium",
  "description": "Infraestructura para compilar modelos del lenguaje Langium definido en prueba.langium",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "langium:generate": "langium generate",
    "build": "tsc",
    "watch": "tsc -w",
    "lint": "eslint src --ext ts",
    "cli": "node ./bin/cli/main.js",
    "generate": "npm run build && node ./bin/cli generate"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^11.0.0",
    "langium": "3.1.0",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.11",
    "vscode-uri": "^3.1.0"
  },
  "devDependencies": {
    "@types/node": "^18.17.5",
    "langium-cli": "3.1.0",
    "typescript": "^5.1.6"
  }
}
